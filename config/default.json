{
    "enabled": true,
    "dryRun": false,
    "proxyPort": 18790,
    "proxyHost": "127.0.0.1",
    "authToken": null,
    "classification": {
        "conservativeMode": true,
        "minConfidence": 0.7,
        "toolAwareRouting": true
    },
    "escalation": {
        "enabled": true,
        "maxRetries": 1,
        "retryDelayMs": 100,
        "onlyRetryBeforeStreaming": true,
        "onlyRetryWithoutToolCalls": false,
        "alwaysFallbackToOriginal": false
    },
    "models": {
        "heartbeat": {
            "primary": "openrouter/google/gemini-2.5-flash",
            "fallback": "openrouter/google/gemini-2.5-flash"
        },
        "simple": {
            "primary": "openrouter/google/gemini-2.5-flash",
            "fallback": "openrouter/google/gemini-2.5-flash"
        },
        "moderate": {
            "primary": "openrouter/google/gemini-2.5-flash",
            "fallback": "openrouter/google/gemini-2.5-flash"
        },
        "complex": {
            "primary": "openrouter/google/gemini-2.5-flash",
            "fallback": "openrouter/google/gemini-2.5-flash"
        },
        "frontier": {
            "primary": "openrouter/google/gemini-2.5-flash",
            "fallback": "openrouter/google/gemini-2.5-flash"
        }
    },
    "logging": {
        "dbPath": "./data/clawroute.db",
        "logContent": false,
        "logSystemPrompts": false,
        "debugMode": false,
        "retentionDays": 30
    },
    "dashboard": {
        "enabled": true
    }
}